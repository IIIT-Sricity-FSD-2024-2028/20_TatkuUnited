---
config:
  layout: elk
---
erDiagram
    Sector {
        BIGINT sector_id PK
        VARCHAR sector_name
        VARCHAR h3_index
        SMALLINT resolution
        VARCHAR state
        VARCHAR region
        DECIMAL centroid_lat
        DECIMAL centroid_lng
        TEXT boundary_geojson
        VARCHAR density_tier
        BOOLEAN is_active
        TIMESTAMPTZ created_at
    }

    Collective_Manager {
        BIGINT collective_manager_id PK
        VARCHAR name
        VARCHAR phone
        VARCHAR email
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Collective {
        BIGINT collective_id PK
        VARCHAR collective_name
        BIGINT collective_manager_id FK
        VARCHAR state
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Collective_Sector {
        BIGINT collective_id FK
        BIGINT sector_id FK
        TIMESTAMPTZ assigned_at
    }

    Unit_Manager {
        BIGINT unit_manager_id PK
        VARCHAR name
        VARCHAR phone
        VARCHAR email
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Unit {
        BIGINT unit_id PK
        BIGINT collective_id FK
        VARCHAR unit_name
        BIGINT unit_manager_id FK
        DECIMAL rating
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Service_Provider {
        BIGINT service_provider_id PK
        BIGINT unit_id FK
        BIGINT sector_id FK
        VARCHAR name
        VARCHAR phone
        VARCHAR email
        DATE dob
        TEXT address
        DECIMAL latitude
        DECIMAL longitude
        VARCHAR gender
        TEXT resume
        TEXT track_record
        TEXT achievements
        VARCHAR timezone
        VARCHAR otp_secret
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Skill {
        BIGINT skill_id PK
        VARCHAR skill_name
        TEXT description
        BOOLEAN is_active
    }

    Provider_Skill {
        BIGINT service_provider_id FK
        BIGINT skill_id FK
        TIMESTAMPTZ verified_at
    }

    Provider_Working_Hours {
        BIGINT working_hour_id PK
        BIGINT service_provider_id FK
        SMALLINT day_of_week
        SMALLINT hour_start
        SMALLINT hour_end
        BOOLEAN is_working
        TIMESTAMPTZ created_at
    }

    Provider_Unavailability {
        BIGINT unavailability_id PK
        BIGINT service_provider_id FK
        DATE date
        SMALLINT hour_start
        SMALLINT hour_end
        VARCHAR reason
        BOOLEAN is_recurring
        VARCHAR recurrence_rule
        DATE recurrence_end_date
        BIGINT parent_unavailability_id FK
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Category {
        BIGINT category_id PK
        BIGINT parent_category_id FK
        VARCHAR category_name
        TEXT description
        VARCHAR icon
        BOOLEAN is_active
    }

    Service {
        BIGINT service_id PK
        BIGINT category_id FK
        BIGINT skill_id FK
        VARCHAR service_name
        TEXT description
        DECIMAL base_price
        INTEGER estimated_duration_min
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Service_Package {
        BIGINT package_id PK
        VARCHAR package_name
        TEXT description
        DECIMAL price
        VARCHAR package_type
        BIGINT created_by_customer_id FK
        BOOLEAN is_active
        TIMESTAMPTZ created_at
    }

    Package_Service {
        BIGINT package_id FK
        BIGINT service_id FK
        SMALLINT quantity
    }

    Customer {
        BIGINT customer_id PK
        VARCHAR name
        VARCHAR phone
        VARCHAR email
        DATE dob
        TEXT address
        DECIMAL latitude
        DECIMAL longitude
        DECIMAL rating
        TEXT notes
        BOOLEAN is_active
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Booking {
        BIGINT booking_id PK
        BIGINT customer_id FK
        BIGINT sector_id FK
        VARCHAR booking_type
        VARCHAR recurrence_rule
        DATE recurrence_end_date
        BIGINT parent_booking_id FK
        TEXT service_address
        DECIMAL service_lat
        DECIMAL service_lng
        TIMESTAMPTZ scheduled_at
        TIMESTAMPTZ slot_locked_until
        VARCHAR lock_held_by
        VARCHAR otp_code
        TIMESTAMPTZ otp_verified_at
        VARCHAR status
        INTEGER version
        TEXT failure_reason
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Booking_Package {
        BIGINT booking_id FK
        BIGINT package_id FK
        DECIMAL price_at_booking
    }

    Job_Assignment {
        BIGINT assignment_id PK
        BIGINT booking_id FK
        BIGINT service_provider_id FK
        DATE scheduled_date
        SMALLINT hour_start
        SMALLINT hour_end
        VARCHAR status
        INTEGER version
        DECIMAL assignment_score
        TEXT notes
        TIMESTAMPTZ assigned_at
        TIMESTAMPTZ updated_at
    }

    Transaction {
        BIGINT transaction_id PK
        BIGINT booking_id FK
        VARCHAR payment_method
        VARCHAR payment_gateway_ref
        VARCHAR idempotency_key
        VARCHAR payment_status
        DECIMAL amount
        CHAR currency
        DECIMAL refund_amount
        TEXT refund_reason
        TIMESTAMPTZ transaction_at
    }

    Notification {
        BIGINT notification_id PK
        VARCHAR recipient_type
        BIGINT recipient_id
        BIGINT booking_id FK
        VARCHAR channel
        VARCHAR event_type
        VARCHAR title
        TEXT body
        TIMESTAMPTZ sent_at
        TIMESTAMPTZ read_at
        TIMESTAMPTZ created_at
    }

    ServiceFAQ {
        BIGINT faq_id PK
        BIGINT service_id FK
        TEXT question
        TEXT answer
        INTEGER display_order
        BOOLEAN is_active
    }

    Review {
        BIGINT review_id PK
        BIGINT booking_id FK
        VARCHAR reviewer_type
        BIGINT reviewer_id
        VARCHAR reviewee_type
        BIGINT reviewee_id
        SMALLINT rating
        TEXT comment
        TIMESTAMPTZ created_at
    }

    Complaint {
        BIGINT complaint_id PK
        BIGINT booking_id FK
        VARCHAR raised_by_type
        BIGINT raised_by_id
        VARCHAR against_type
        BIGINT against_id
        TEXT complaint_text
        DATE complaint_date
        BIGINT assigned_to
        VARCHAR status
        TEXT resolution_notes
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    Audit_Log {
        BIGINT log_id PK
        VARCHAR table_name
        BIGINT record_id
        VARCHAR operation
        VARCHAR changed_by_type
        BIGINT changed_by_id
        JSONB old_values
        JSONB new_values
        TIMESTAMPTZ changed_at
    }
    Collective_Manager ||--|| Collective : "manages"
    Collective ||--|{ Unit : "contains"
    Unit_Manager ||--|| Unit : "manages"
